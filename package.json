{
  "name": "silence-editor",
  "version": "1.0.1",
  "type": "module",
  "description": "Professional AI Silence Removal Audio Editor",
  "main": "./out/main/index.cjs",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "node scripts/clean-release.mjs && npm run build && electron-builder --win nsis",
    "dist:alt": "node scripts/clean-release.mjs release-build && npm run build && electron-builder --win nsis --config.directories.output=release-build",
    "dist:portable": "npm run build && electron-builder --win portable",
    "dist:dir": "npm run build && electron-builder --win dir",
    "postinstall": "node scripts/install-electron.js"
  },
  "dependencies": {
    "@higgsfield/cli": "^1.1.5",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-select": "^2.1.6",
    "@radix-ui/react-slider": "^1.2.3",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.1.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "lucide-react": "^0.475.0",
    "onnxruntime-node": "^1.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hotkeys-hook": "^4.6.1",
    "tailwind-merge": "^3.0.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "postcss": "^8.5.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  },
  "build": {
    "appId": "com.silence-editor.app",
    "productName": "Silence Editor",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release",
      "buildResources": "resources"
    },
    "compression": "maximum",
    "electronLanguages": ["en-US"],
    "files": [
      "out/**/*",
      "resources/**/*",
      "package.json",
      "!node_modules/onnxruntime-node/bin/**/darwin/**",
      "!node_modules/onnxruntime-node/bin/**/linux/**",
      "!node_modules/onnxruntime-node/bin/**/win32/arm64/**"
    ],
    "extraResources": [
      {
        "from": "resources/models/",
        "to": "models",
        "filter": ["**/*"]
      }
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**",
      "**/node_modules/onnxruntime-node/**",
      "**/node_modules/@higgsfield/cli/vendor/**"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "differentialPackage": false,
      "installerLanguages": ["en_US"]
    }
  }
}
